# Token do Bot do Telegram (obtenha com o @BotFather)
TELEGRAM_BOT_TOKEN=seu_token_do_telegram_aqui

# URL base do servidor local do LM Studio
LM_STUDIO_URL=http://localhost:1234/v1

# Nome do modelo carregado no LM Studio
MODEL_NAME=local-model

# Temperatura de geração (0.0 = determinístico, 1.0 = criativo)
TEMPERATURE=0.7

# Mensagem de sistema para ditar o comportamento do modelo
# NOTA: Quando AGENTS_ENABLED=true, cada agente usa seu próprio system prompt
# e este valor é ignorado. Ele só é usado no modo sem agentes.
SYSTEM_PROMPT=""

# IDs de Telegram permitidos (separados por vírgula). Deixe vazio para permitir todos.
# Exemplo: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Número máximo de mensagens no histórico por sessão
MAX_HISTORY_LENGTH=800

# ==== MULTI-AGENT (Sistema de Agentes Especializados) ====

# Habilitar/desabilitar o sistema multi-agente (true/false)
AGENTS_ENABLED=true

# Modelo para o roteador (pode ser diferente do modelo principal)
ROUTER_MODEL=local-model

# Habilitar/desabilitar agentes individuais
AGENT_CODER_ENABLED=true
AGENT_RESEARCHER_ENABLED=true
AGENT_CREATIVE_ENABLED=true
AGENT_ANALYST_ENABLED=true

# ==== MEMPALACE (Memória de Longo Prazo) ====

# Habilitar/desabilitar o MemPalace (true/false)
MEMPALACE_ENABLED=true

# Número de memórias relevantes a injetar no contexto do LLM
MEMPALACE_RESULTS=3

# Nome do "wing" no palace (agrupa memórias por projeto)
MEMPALACE_WING=telegram_bot

# ==== RATE LIMITING ====

# Intervalo mínimo entre mensagens por usuário (segundos)
# Evita spam e sobrecarga do LLM
MIN_MSG_INTERVAL=2.0
